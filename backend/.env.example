DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,hiigsi-app.onrender.com
TIME_ZONE=UTC

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://hiigsi-tracker.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://hiigsi-tracker.vercel.app

SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=true
SECURE_HSTS_INCLUDE_SUBDOMAINS=true

JWT_ALGORITHM=HS256
JWT_ACCESS_MIN=30
JWT_REFRESH_DAYS=7

WEBAUTHN_RP_ID=hiigsi-tracker.vercel.app
WEBAUTHN_RP_NAME=Hiigsi Tracker
WEBAUTHN_ORIGIN=https://hiigsi-tracker.vercel.app
