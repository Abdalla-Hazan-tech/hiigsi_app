# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=UTC

# Database
# For Docker dev
DATABASE_URL=postgres://postgres:postgres@db:5432/protrack
# Or for local dev with sqlite fallback (comment out the line above)
# DATABASE_URL=sqlite:///db.sqlite3

# Cache/Queues
REDIS_URL=redis://redis:6379/0

# CORS
DEV_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ALGORITHM=HS256
# For RS256, provide JWT_SIGNING_KEY (private) and JWT_VERIFYING_KEY (public)

# Security (enable in production)
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_PRELOAD=false
SECURE_HSTS_INCLUDE_SUBDOMAINS=false

# DRF throttles
DRF_THROTTLE_AUTH=5/min
DRF_THROTTLE_USER=120/min
DRF_THROTTLE_ANON=60/min

# MFA
MFA_ISSUER=ProTrack
MFA_TICKET_TTL=300
